# CzechMedMCP Environment Variables
# Copy to .env and fill in values as needed.

# --- Deployment ---
# Railway: MCP_MODE a PORT se nastaví automaticky
# MCP_MODE=streamable_http
# PORT=8000

# --- MCP Server Auth (doporučeno pro HTTPS deploy) ---
# Minimálně 32 znaků. Generování: openssl rand -hex 32
# MCP_AUTH_TOKEN=your-mcp-auth-token-min-32-chars

# --- Optional API Keys ---
# NCI_API_KEY=your-nci-api-key
# OPENFDA_API_KEY=your-openfda-api-key
# ONCOKB_TOKEN=your-oncokb-token
# ALPHAGENOME_API_KEY=your-alphagenome-api-key
# CBIO_TOKEN=your-cbioportal-token

# --- Runtime Configuration ---
# Note: These use the legacy BIOMCP_ prefix for backward compatibility.
# The source code reads these env vars directly.
# BIOMCP_OFFLINE=false                   # Disables all live API calls
# BIOMCP_USE_CONNECTION_POOL=true        # Enable HTTP connection pooling
# BIOMCP_METRICS_ENABLED=false           # Enable performance metrics collection

# --- OpenFDA cache tuning ---
# BIOMCP_FDA_CACHE_TTL=15               # Cache TTL in minutes
# BIOMCP_FDA_MAX_CACHE_SIZE=100         # Max cached responses
# BIOMCP_FDA_MAX_RESPONSE_SIZE=1048576  # Max response size (bytes)
# BIOMCP_SHORTAGE_CACHE_TTL=24          # Drug shortage cache TTL (hours)
