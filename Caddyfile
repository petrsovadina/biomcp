# Caddyfile — auto HTTPS via Let's Encrypt
# Nastavte doménu v .env: DOMAIN=mcp.example.com
{$DOMAIN:localhost} {
    # MCP endpoint — proxy na Python server
    handle /mcp* {
        reverse_proxy mcp-server:8000
    }

    # Health check
    handle /health {
        reverse_proxy mcp-server:8000
    }

    # Landing page — statické soubory
    handle {
        root * /srv/web
        file_server
        try_files {path} {path}.html /index.html
    }

    # Logging
    log {
        output stdout
        format json
    }

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }
}
