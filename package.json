{
  "name": "czechmedmcp",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean && rm -rf node_modules",
    "dev:web": "turbo dev --filter=web",
    "dev:docs": "turbo dev --filter=czechmedmcp-docs",
    "build:web": "turbo build --filter=web",
    "build:docs": "turbo build --filter=czechmedmcp-docs"
  },
  "devDependencies": {
    "turbo": "^2"
  },
  "packageManager": "npm@10.9.2",
  "overrides": {
    "unist-util-modify-children": "3.1.1"
  }
}
